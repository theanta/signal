SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
GROQ_API_KEY=your-groq-api-key
APIFY_API_TOKEN=your-apify-api-token
SCRAPER_DELAY_MS=1500
SCRAPER_MAX_RETRIES=3
PORT=8001

# ---- Enrichment APIs ----
# Serper (Google Search) — used to find/verify company websites
# Get a free key at https://serper.dev (2,500 free queries/mo)
SERPER_API_KEY=your-serper-api-key

# Apollo.io — used to find decision-maker contacts
# Get your API key at https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=your-apollo-api-key

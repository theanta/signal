# ============================================================
# ANTA LEAD RADAR - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---- Supabase ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Groq AI (free tier — https://console.groq.com) ----
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-70b-versatile

# ---- Backend API ----
BACKEND_PORT=3001
BACKEND_URL=http://localhost:3001
NODE_ENV=development
JWT_SECRET=change-this-in-production

# ---- Signal Engine (Python FastAPI) ----
SIGNAL_ENGINE_PORT=8001
SIGNAL_ENGINE_URL=http://localhost:8001

# ---- Frontend ----
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---- Scraper Config ----
SCRAPER_DELAY_MS=1500
SCRAPER_MAX_RETRIES=3
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; ANTALeadRadar/1.0)

# ---- Cron Schedules (cron syntax) ----
CRON_DAILY_SCRAPE=0 6 * * *
CRON_ANALYZE_LEADS=0 7 * * *
CRON_GENERATE_OUTREACH=0 8 * * *

# ---- Rate Limits ----
CLAUDE_REQUESTS_PER_MINUTE=30
SCRAPER_REQUESTS_PER_MINUTE=10
